# =============================================================================
# night-runner .gitignore
# 公開リポジトリ。利用者の「実作業(jobの中身)・実行ログ・生成物・認証情報」が
# 誤ってコミット/公開されないようにする。サンプル/テンプレ/コードだけ追跡する。
# =============================================================================

# --- install が生成するマシン固有設定（パス/環境固有値を含む）---------------
config/config.sh
config/config.sh.bak

# --- 実行結果・ログ・生成物・状態（ローカルの記録。公開しない）---------------
# runs/ 配下すべて: 実行ログ / <date>-summary.md / state マーカー /
#                   safety.log / scratch 生成物 / launchd.*.log / .only-job
runs/*
!runs/README.md
!runs/.gitkeep

# --- 利用者の実 job は追跡しない（job の中身は業務データになりうる）----------
# サンプルだけ追跡。setup-job が作る jobs/<名>/ は既定で ignore される。
jobs/*/
!jobs/sample-hello/

# --- 認証情報・秘密が入りうるファイル（防御的に広めに）-----------------------
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
id_ed25519*
*.p12
.netrc
credentials.json
# Claude Code のローカル設定（権限許可リスト等。環境固有）
.claude/settings.local.json

# --- OS ---------------------------------------------------------------------
.DS_Store
