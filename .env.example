# night-runner .env テンプレート（追跡可・値は入れない）
# 使い方:  cp .env.example .env  して .env に値を入れる。
# .env 本体は .gitignore 済み＝トークンはコミットされない。
# runner が起動時に読み込み、claude とその安全フック(guard.py)に env として渡す。
#
# ※ 値に # や \ や空白を含むものは必ず「単一引用符」で囲むこと
#   （シェルが読み込むため。# はコメント開始、\ はエスケープと解釈されてしまう）。

# --- Chatwork 投稿用（jobs/idea-discovery-nightly 等）------------------------
CHATWORK_BOT_API_TOKEN=
CHATWORK_ROOM_ID=

# job の動作モード:  dry-run = 投稿せず整形出力のみ / live = 実投稿
# 既定は dry-run。本番投稿は明示的に live に変えてから。
IDEAS_MODE=dry-run

# --- 安全境界: サンクション済み送信先 allowlist（guard.py が参照）------------
# 「意図した外部送信だけ」を通すための URL 正規表現（空白/カンマ区切りで複数可）。
# guard.py は「全URLが一致 かつ 秘密ファイル不参照」の2条件でだけ送信を許可する。
# これを空にすると Chatwork 投稿も従来どおりブロックされる（＝より安全側）。
NR_ALLOWED_SEND_URLS='^https://api\.chatwork\.com/v2/rooms/[^/?#]+/messages$'
